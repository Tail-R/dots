<?xml version="1.0" encoding="utf-8"?>
<openbox_menu xmlns="http://openbox.org/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://openbox.org/ file:///usr/share/openbox/menu.xsd">

  <menu id="root-menu" label="Openbox 3">
    <item label="Terminal">
      <action name="Execute">
        <command>urxvt</command>
      </action>
    </item>
    <item label="Text Editor">
      <action name="Execute">
        <command>vscodium</command>
      </action>
    </item>
    <item label="Web Browser">
      <action name="Execute">
        <command>firefox</command>
      </action>
    </item>
    <item label="File Manager">
      <action name="Execute">
        <command>thunar</command>
      </action>
    </item>

    <!-- Applications submenu -->
    <separator/>
    <menu id="applications" label="Applications">
      <item label="Libreoffice">
        <action name="Execute">
          <command>libreoffice</command>
        </action>
      </item>
      <item label="Inkscape">
        <action name="Execute">
          <command>inkscape</command>
        </action>
      </item>
      <item label="OBS Studio">
        <action name="Execute">
          <command>obs</command>
        </action>
      </item>
      <item label="VLC media player">
        <action name="Execute">
          <command>vlc</command>
        </action>
      </item>
      <item label="Timer">
        <action name="Execute">
          <command>gnome-clocks</command>
        </action>
      </item>
      <item label="Calculator">
        <action name="Execute">
          <command>gnome-calculator</command>
        </action>
      </item>

      <!-- Games -->
      <menu id="games" label="Games">
        <item label="Minesweeper">
          <action name="Execute">
            <command>gnome-mines</command>
          </action>
        </item>
        <item label="Solitaire">
          <action name="Execute">
            <command>sol</command>
          </action>
        </item>
      </menu>

      <!-- Screenshot -->
      <menu id="screenshot" label="Screenshot">
        <item label="entire-screen">
          <action name="Execute">
            <command>shot -e</command>
          </action>
        </item>
        <item label="primary-monitor">
          <action name="Execute">
            <command>shot -p</command>
          </action>
        </item>
        <item label="selection">
          <action name="Execute">
            <command>shot -s</command>
          </action>
        </item>
      </menu>

      <!-- Settings -->
      <menu id="settings" label="Settings">
        <item label="lxappearance">
          <action name="Execute">
            <command>lxappearance</command>
          </action>
        </item>
        <item label="pavucontrol">
          <action name="Execute">
            <command>pavucontrol</command>
          </action>
        </item>
        <item label="fcitx5-configtool">
          <action name="Execute">
            <command>fcitx5-configtool</command>
          </action>
        </item>
      </menu>
    </menu>

    <!-- Openbox -->
    <separator/>
    <menu id="openbox" label="Openbox">
      <menu id="themes" label="Themes">
        <item label="Default-Light">
          <action name="Execute"><command>switch-theme default-light</command></action>
        </item>
        <item label="Moss">
          <action name="Execute"><command>switch-theme moss</command></action>
        </item>
      </menu>
      <item label="Reconfigure">
        <action name="Reconfigure"/>
      </item>
      <item label="Restart">
        <action name="Restart"/>
      </item>
      <item label="Exit">
        <action name="Exit"/>
      </item>
    </menu>

    <!-- System -->
    <menu id="system" label="System">
      <item label="Sleep">
        <action name="Execute">
          <command>systemctl suspend</command>
        </action>
      </item>
      <item label="Reboot">
        <action name="Execute">
          <command>systemctl reboot</command>
        </action>
      </item>
      <item label="Shutdown">
        <action name="Execute">
          <command>systemctl poweroff</command>
        </action>
      </item>
    </menu>
  </menu>

</openbox_menu>

