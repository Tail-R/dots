border.width: 2
window.titlebar.padding.width: 6
window.titlebar.padding.height: 6
window.active.border.color: #cccccc
window.inactive.border.color: #cccccc

# Active window
window.active.title.bg: Gradient SplitVertical
window.active.title.bg.color: #c4c3d0
window.active.title.bg.color.splitTo: #fafafa
window.active.title.bg.colorTo: #c4c3d0
window.active.title.bg.colorTo.splitTo: #cdcfdb

# Inactive window
window.inactive.title.bg: Gradient SplitVertical
window.inactive.title.bg.color: #c4c3d0
window.inactive.title.bg.color.splitTo: #fafafa
window.inactive.title.bg.colorTo: #c4c3d0
window.inactive.title.bg.colorTo.splitTo: #cdcfdb

window.active.label.text.color: #24292f
window.inactive.label.text.color: #899499

window.label.text.justify: Left
window.button.width: 32
window.button.height: 32
window.button.spacing: 2

window.*.shadow.size: 60
window.*.shadow.color: #00000045

# Menus
menu.overlap.x: 0
menu.overlap.y: 0
menu.width.min: 20
menu.width.max: 200
menu.items.padding.x: 4
menu.items.padding.y: 2
menu.items.bg.color: #fafafa
menu.items.text.color: #36454f
menu.items.active.bg.color: #c4c3d0
menu.items.active.text.color: #36454f
menu.separator.width: 1
menu.separator.padding.width: 0
menu.separator.padding.height: 0
menu.separator.color: #aaaaaa
menu.title.bg.color: #c4c3d0
menu.title.text.justify: Left
menu.title.text.color: #36454f

# OSDs
osd.bg.color: #fafafa
osd.label.text.color: #666666

