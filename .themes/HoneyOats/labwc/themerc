border.width: 2
window.titlebar.padding.width: 4
window.titlebar.padding.height: 4
window.active.border.color: #c4c4c4
window.inactive.border.color: #c4c4c4

# Active window
window.active.title.bg: Gradient SplitVertical
window.active.title.bg.color: #c4c3d0
window.active.title.bg.color.splitTo: #ffffff
window.active.title.bg.colorTo: #c4c3d0
window.active.title.bg.colorTo.splitTo: #a4a3af

# Inactive window
window.inactive.title.bg: Gradient SplitVertical
window.inactive.title.bg.color: #c4c3d0
window.inactive.title.bg.color.splitTo: #ffffff
window.inactive.title.bg.colorTo: #c4c3d0
window.inactive.title.bg.colorTo.splitTo: #a4a3af

window.active.label.text.color: #686773
window.inactive.label.text.color: #74737f

window.label.text.justify: Left
window.button.width: 32
window.button.height: 32
window.button.spacing: 2
window.button.hover.bg.color: #80808037
window.button.hover.bg.corner-radius: 8

window.*.shadow.size: 16
window.*.shadow.color: #00000075

# Menus
menu.overlap.x: 0
menu.overlap.y: 0
menu.width.min: 60
menu.width.max: 200
menu.items.padding.x: 4
menu.items.padding.y: 2
menu.items.bg.color: #fafafa
menu.items.text.color: #24292f
menu.items.active.bg.color: #e1e5ea
menu.items.active.text.color: #24292f
menu.separator.width: 1
menu.separator.padding.width: 0
menu.separator.padding.height: 0
menu.separator.color: #aaaaaa
menu.title.bg.color: #c6c4c5
menu.title.text.justify: Left
menu.title.text.color: #24292f

# OSDs
osd.bg.color: #fafafa
osd.label.text.color: #666666

