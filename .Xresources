#include "/home/tailr/.config/X11/colors/current"
#include "/home/tailr/.config/nsxiv/config"

!! Xft
Xft.dpi: 96
Xft.antialias: true
Xft.autohint: false
Xft.hinting: false
Xft.hintstyle: hintslight

!! Xterm
XTerm.vt100.faceName: monospace
XTerm.vt100.faceSize: 11
XTerm.vt100.geometry: 96x32
XTerm.vt100.scrollBar: true
XTerm.vt100.saveLines: 4096
XTerm.vt100.internalBorder: 0

!! Urxvt

!! Bitmap font
! urxvt*font: xft:tamzen:style=regular:pixelsize=20
! urxvt*boldfont: xft:tamzen:style=bold:pixelsize=20
! urxvt*italicfont: xft:tamzen:style=bold:pixelsize=20

!! Vector font
urxvt*font: xft:IBMPlexMono:style=regular:size=11, \
    xft:IBMPlexSansJP:style=regular:size=11
urxvt*boldfont: xft:IBMPlexMono:style=bold:size=11
urxvt*italicfont: xft:IBMPlexMono:style=bold:size=11

URxvt*letterSpace: 0
URxvt*geometry: 96x32
URxvt*scrollBar: true
URxvt*scrollBar_right: true
URxvt*thickness: 12
URxvt*cursorUnderline: false
URxvt*cursorBlink: true
URxvt*saveLines: 4096
URxvt*internalBorder: 0
URxvt*urlLauncher: firefox
URxvt*underlineURLs: true

URxvt*keysym.Control-Shift-C: eval:selection_to_clipboard
URxvt*keysym.Control-Shift-V: eval:paste_clipboard

